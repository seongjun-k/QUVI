# Innomaker U20CAM 카메라는 고유 시리얼 번호가 SN0001로 중복되므로,
# USB 물리 포트 위치(KERNELS)를 기반으로 구분하여 심볼릭 링크를 생성합니다.
# 또한 장치 인식 시점에 v4l2-ctl을 구동하여 전원 플리커 차단(60Hz) 설정을 강제합니다.

# Handcam / Sidecam (사이드캠/핸드캠) - USB 포트 1-3.3 연결 (원래 /dev/video4)
SUBSYSTEM=="video4linux", KERNELS=="1-3.3:1.0", ATTR{index}=="0", SYMLINK+="handcam sidecam", RUN+="/usr/bin/v4l2-ctl -d /dev/%k --set-ctrl=power_line_frequency=2"

# Fixed Camera (고정캠) - USB 포트 1-3.1 연결 (원래 /dev/video2)
SUBSYSTEM=="video4linux", KERNELS=="1-3.1:1.0", ATTR{index}=="0", SYMLINK+="fixed_cam", RUN+="/usr/bin/v4l2-ctl -d /dev/%k --set-ctrl=power_line_frequency=2"
